# Application
APP_PORT=3000
NODE_ENV=production

# Security - CHANGE THESE!
JWT_SECRET=your-super-secret-jwt-key-change-this-now
JWT_EXPIRY=7d

# Database
DB_PATH=/app/data/dashboard.db

# Sonarr
SONARR_URL=http://192.168.1.x:8989
SONARR_API_KEY=your-sonarr-api-key

# Radarr
RADARR_URL=http://192.168.1.x:7878
RADARR_API_KEY=your-radarr-api-key

# Overseerr
OVERSEERR_URL=http://192.168.1.x:5055
OVERSEERR_API_KEY=your-overseerr-api-key

# SABnzbd
SABNZBD_URL=http://192.168.1.x:8080
SABNZBD_API_KEY=your-sabnzbd-api-key

# Plex
PLEX_URL=http://192.168.1.x:32400
PLEX_TOKEN=your-plex-token

# Tautulli
TAUTULLI_URL=http://192.168.1.x:8181
TAUTULLI_API_KEY=your-tautulli-api-key
